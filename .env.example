# Copy to .env and fill in real values for live payments.
# Tests and mock providers do NOT need real keys.

# --- Solana ---
SOLANA_PRIVATE_KEY=mock-solana-private-key-base58
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
# Optional: USDC mint (mainnet default used if empty)
SOLANA_USDC_MINT=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v

# --- EVM / Base (x402) ---
BASE_PRIVATE_KEY=0xmock_base_private_key_hex
BASE_RPC_URL=https://mainnet.base.org
# Chain id: Base mainnet = 8453
BASE_CHAIN_ID=8453

# --- Fiat (Payman / Stripe-like adapter) ---
PAYMAN_API_KEY=mock-payman-api-key
PAYMAN_API_URL=https://api.paymanai.com/v1
FIAT_WEBHOOK_SECRET=mock-webhook-secret

# --- Agent defaults ---
PAYAGENT_DAILY_LIMIT=10.0
PAYAGENT_MAX_PER_TX=0.50
PAYAGENT_MONTHLY_LIMIT=100.0
PAYAGENT_SPEND_DB=./payagent_spend.db
