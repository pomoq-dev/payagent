# payagent configuration — copy to .env (never commit real secrets)

# --- Mode ---
# 1 = mock rails (default, safe). 0 = require keys/signers for live/testnet.
PAYAGENT_MOCK=1
PAYAGENT_MOCK_BALANCE=1000
PAYAGENT_DEFAULT_CURRENCY=USDC

# --- Budget policy ---
PAYAGENT_MAX_PER_TX=0.50
PAYAGENT_DAILY_LIMIT=10.0
PAYAGENT_MONTHLY_LIMIT=100.0
# Comma-separated hostnames (empty = allow all)
PAYAGENT_ALLOWLIST_DOMAINS=
# Optional HITL threshold (unset = disabled)
# PAYAGENT_REQUIRE_HUMAN_APPROVAL_ABOVE=2.0
# SQLite spend ledger + payment journal path
PAYAGENT_SPEND_DB=./payagent_spend.db

# --- Base / EVM (defaults = Base Sepolia testnet) ---
BASE_PRIVATE_KEY=
BASE_RPC_URL=https://sepolia.base.org
BASE_CHAIN_ID=84532
BASE_NETWORK=base-sepolia

# --- Solana (defaults = devnet) ---
SOLANA_PRIVATE_KEY=
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_USDC_MINT=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU

# --- Fiat REST adapter ---
PAYMAN_API_KEY=
PAYMAN_API_URL=https://api.paymanai.com/v1
